# ─── Database (split for security) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow_user
DB_PASSWORD=your_password_here
DB_SCHEMA=public

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7

# ─── App ──────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ─── Vault Encryption ────────────────────────────────────
VAULT_KEY_V1=generate-a-64-char-hex-key-here
VAULT_CURRENT_VERSION=1

# ─── Storage (DigitalOcean Spaces) ───────────────────────
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ─── Email (AWS SES) ─────────────────────────────────────
AWS_SES_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
